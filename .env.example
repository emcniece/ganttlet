NODE_ENV=development
PORT=3000

# Database
DATABASE_PATH=./data/ganttlet.db

# Sessions
SESSION_SECRET=change-me-to-a-random-string

# URLs
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Path to frontend dist (production only, leave empty for dev)
STATIC_DIR=

# Frontend API URL (optional - for static deployments pointing to a remote backend)
# VITE_API_URL=https://ganttlet-api.example.com/api

# OAuth (optional - backend works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
